<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>Big Beautiful Workout App</string>
	<key>CFBundleName</key>
	<string>Big Beautiful Workout App</string>
	<key>NSHealthShareUsageDescription</key>
	<string>Davis's Big Beautiful Workout App reads your Apple Health data, such as workouts, sleep, activity, cardio, and recovery metrics, to power workout insights and training history.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>Davis's Big Beautiful Workout App requests HealthKit update permission because iOS requires it for the workout data access used by the app, but the app does not write health samples.</string>
	<key>NSUbiquitousContainers</key>
	<dict>
		<key>iCloud.davis.workout-app</key>
		<dict>
			<key>NSUbiquitousContainerIsDocumentScopePublic</key>
			<true/>
			<key>NSUbiquitousContainerName</key>
			<string>Davis's Big Beautiful Workout App</string>
			<key>NSUbiquitousContainerSupportedFolderLevels</key>
			<string>Any</string>
		</dict>
	</dict>
	<key>UIAppFonts</key>
	<array>
		<string>BebasNeue-Regular.ttf</string>
	</array>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>LaunchBackground</string>
		<key>UIImageName</key>
		<string>AppIcon</string>
	</dict>
</dict>
</plist>
